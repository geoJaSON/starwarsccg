{
  "name": "swccg-catalogue",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A collection catalogue for the original Decipher Star Wars Customizable Card Game (1995–2001)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "build-cards": "node scripts/build-cards.mjs"
  },
  "dependencies": {
    "idb-keyval": "^6.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
